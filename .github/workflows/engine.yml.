name: Windows Engine
on:
  repository_dispatch:
    types: [convert_etl]
  workflow_dispatch:

jobs:
  convert:
    runs-on: windows-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4
      - name: Run
        shell: pwsh
        run: |
          Invoke-WebRequest -Uri "${{ github.event.client_payload.etl_url }}" -OutFile "i.etl"
          .\etl2pcapng.exe i.etl o.pcap
          curl.exe -X POST -F "file=@o.pcap" -F "taskId=${{ github.event.client_payload.task_id }}" "${{ github.event.client_payload.return_url }}"
